# Telegram user-account credentials for the TEST account that talks to your bots.
# Get api_id / api_hash from https://my.telegram.org -> API development tools.
TG_API_ID=123456
TG_API_HASH=0123456789abcdef0123456789abcdef
# Phone number of the test user account (international format), used for first login only.
TG_PHONE=+10000000000
# Session file name (Telethon stores the login here so you don't re-auth every run).
TG_SESSION=tgtest.session
# Optional: default bot to talk to when a scenario doesn't specify one.
TG_DEFAULT_BOT=@my_bot
# Optional proxy for the user client. One URL; pick the form you need:
#   socks5://127.0.0.1:9050           socks5h:// to resolve DNS via the proxy
#   socks5://user:pass@host:1080      (percent-encode special chars in user/pass)
#   http://proxy.local:3128
#   mtproxy://SECRET@host:443         Telegram MTProxy (or ?secret=SECRET)
# TG_PROXY=socks5://127.0.0.1:9050
# Default per-step reply timeout in seconds.
TG_TIMEOUT=15
# Logging.
TG_APP_NAME=tgtest
TG_LOG_LEVEL=INFO
